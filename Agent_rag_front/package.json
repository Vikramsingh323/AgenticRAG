{
  "name": "rag-chatbot-fullstack",
  "version": "1.0.0",
  "description": "RAG-powered chatbot with React frontend and Flask backend",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "./run_backend.sh",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "type-check": "cd frontend && tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
